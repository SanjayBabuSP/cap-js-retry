{
  "name": "cap-js-retry",
  "version": "1.0.0",
  "description": "Automatic retry with exponential backoff for SAP CAP RemoteService calls",
  "main": "cds-plugin.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest --forceExit",
    "test:unit": "jest --forceExit --testPathPattern='test/[^/]+\\.test\\.ts$'",
    "test:integration": "jest --forceExit --testPathPattern='test/integration'",
    "test:dry-run": "npm run build && npm pack --dry-run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sap",
    "cap",
    "cds",
    "cds-plugin",
    "cap-plugin",
    "retry",
    "backoff",
    "resilience",
    "remote-service"
  ],
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@sap/cds": ">=9"
  },
  "devDependencies": {
    "@sap/cds": "^9",
    "@sap/cds-dk": "^9",
    "@cap-js/sqlite": "^1",
    "@cap-js/cds-test": "^0",
    "eslint": "^9",
    "typescript-eslint": "^8",
    "eslint-config-prettier": "^9",
    "prettier": "^3",
    "jest": "^29",
    "ts-jest": "^29",
    "typescript": "^5",
    "@types/jest": "^29",
    "@types/node": "^22",
    "semantic-release": "^23",
    "@semantic-release/changelog": "^6",
    "@semantic-release/git": "^10"
  },
  "files": [
    "cds-plugin.js",
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SanjayBabuSP/cap-js-retry.git"
  },
  "bugs": {
    "url": "https://github.com/SanjayBabuSP/cap-js-retry/issues"
  },
  "homepage": "https://github.com/SanjayBabuSP/cap-js-retry#readme",
  "author": "SanjayBabu SP",
  "license": "Apache-2.0"
}
